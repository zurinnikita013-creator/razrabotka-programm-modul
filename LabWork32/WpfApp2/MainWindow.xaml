<Window x:Class="LabWork32.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог товаров" Height="600" Width="900">

    <Window.Resources>
        <!-- Картинка-заглушка -->
        <ImageBrush x:Key="PlaceholderImage" ImageSource="https://via.placeholder.com/80x80?text=No+Image" 
                    Stretch="Uniform" />

        <!-- Шаблон для плитки (WrapPanel) -->
        <ItemsPanelTemplate x:Key="TilePanelTemplate">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <!-- Шаблон для списка (VirtualizingStackPanel) -->
        <ItemsPanelTemplate x:Key="ListPanelTemplate">
            <VirtualizingStackPanel Orientation="Vertical" />
        </ItemsPanelTemplate>

        <!-- DataTemplate для отображения в виде карточек (плитка) -->
        <DataTemplate x:Key="TileTemplate">
            <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10" Width="180" Height="150">
                <StackPanel>
                    <Rectangle Fill="{StaticResource PlaceholderImage}" Width="80" Height="80" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding Price, StringFormat='{0:C}'}" Foreground="Green"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- DataTemplate для отображения в виде списка -->
        <DataTemplate x:Key="ListTemplate">
            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Fill="{StaticResource PlaceholderImage}" Width="60" Height="60" Grid.Column="0"/>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Grid.Column="1" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Category}" Grid.Column="2" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Price, StringFormat='{0:C}'}" Grid.Column="3" VerticalAlignment="Center" Foreground="Green"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - фильтры -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Margin="0,0,10,0">
            <!-- Список категорий (горизонтальный с прокруткой) -->
            <TextBlock Text="Список категорий товаров:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox x:Name="CategoryListBox" Height="100" Margin="0,0,0,10" 
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     SelectionChanged="CategoryListBox_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <!-- Наличие (CheckBox список) -->
            <TextBlock Text="Наличие:" FontWeight="Bold" Margin="0,10,0,5"/>
            <ListBox x:Name="AvailabilityListBox" Margin="0,0,0,10" BorderThickness="0">
                <CheckBox x:Name="InStockCheck" Content="в наличии" IsChecked="True"/>
                <CheckBox x:Name="OrderTodayCheck" Content="под заказ: сегодня" IsChecked="True"/>
                <CheckBox x:Name="OrderTomorrowCheck" Content="под заказ: завтра" IsChecked="True"/>
                <CheckBox x:Name="OrderLaterCheck" Content="под заказ: позже" IsChecked="True"/>
                <CheckBox x:Name="NotAvailableCheck" Content="нет в продаже" IsChecked="False"/>
            </ListBox>

            <!-- Кнопка Применить -->
            <Button x:Name="ApplyButton" Content="Применить" Click="ApplyButton_Click" Margin="0,5,0,15"/>

            <!-- Сортировка (ComboBox) -->
            <TextBlock Text="Сортировка:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="SortComboBox" SelectionChanged="SortComboBox_SelectionChanged">
                <ComboBoxItem Content="сначала недорогие" IsSelected="True"/>
                <ComboBoxItem Content="сначала дорогие"/>
                <ComboBoxItem Content="по новинкам"/>
                <ComboBoxItem Content="по скидке"/>
                <ComboBoxItem Content="по количеству отзывов"/>
                <ComboBoxItem Content="сначала с лучшей оценкой"/>
            </ComboBox>

            <!-- TextBlock для отображения выбранного -->
            <TextBlock x:Name="SortTextBlock" Margin="0,10,0,0" FontStyle="Italic"/>
            <TextBlock x:Name="CategoryTextBlock" FontStyle="Italic"/>
            <TextBlock x:Name="AvailabilityTextBlock" FontStyle="Italic" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Центральная панель - список товаров -->
        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <ToggleButton x:Name="TileViewButton" Content="Плитка" Width="80" Margin="0,0,5,0" 
                              Click="TileViewButton_Click" IsChecked="True"/>
                <ToggleButton x:Name="ListViewButton" Content="Список" Width="80" 
                              Click="ListViewButton_Click"/>
            </StackPanel>

            <ListView x:Name="ProductsListView" ItemsSource="{Binding}" 
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </StackPanel>

        <!-- Правая панель - корзина -->
        <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Margin="10,0,0,0">
            <TextBlock Text="Корзина:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox x:Name="CartListBox" Height="300" SelectionMode="Extended" 
                     DisplayMemberPath="Name" Margin="0,0,0,10"/>
            <Button x:Name="BuyButton" Content="Купить" Click="BuyButton_Click" Margin="0,5"/>
            <Button x:Name="DeleteButton" Content="Удалить" Click="DeleteButton_Click" Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>