<Window x:Class="LabWork32.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabWork32"
        mc:Ignorable="d"
        Title="Каталог товаров" Height="600" Width="900">

    <Window.Resources>
        <BitmapImage x:Key="ProductPlaceholder" UriSource="/picture.png" />

        <ItemsPanelTemplate x:Key="TilePanelTemplate">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="ListPanelTemplate">
            <VirtualizingStackPanel Orientation="Vertical" />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="CardTemplate">
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                    Margin="5" Padding="5" Width="180">
                <StackPanel>
                    <Image Source="{StaticResource ProductPlaceholder}" 
                           Width="150" Height="100" Stretch="Uniform" Margin="5"/>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,5" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Category}" FontSize="10" Foreground="Gray"/>
                    <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" Foreground="Green" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ListTemplate">
            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" Width="200" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Category}" Width="120"/>
                    <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" Width="100" Foreground="Green"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="Black" BorderThickness="1" Padding="5" Margin="0,0,0,10" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Список категорий товаров:" 
                           FontWeight="Bold" Margin="0,5,10,0" VerticalAlignment="Top"/>
                <ListBox x:Name="lbCategories" Grid.Row="0" Grid.Column="1" 
                         Height="80" SelectionMode="Single"
                         SelectionChanged="LbCategories_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Наличие:" 
                           FontWeight="Bold" Margin="0,5,10,0" VerticalAlignment="Top"/>
                <ListBox x:Name="lbAvailability" Grid.Row="1" Grid.Column="1" Height="100">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="Сортировка:" FontWeight="Bold" Margin="0,0,10,5"/>
                    <ComboBox x:Name="cbSort" Width="150" SelectionChanged="CbSort_SelectionChanged">
                        <ComboBoxItem IsSelected="True">сначала недорогие</ComboBoxItem>
                        <ComboBoxItem>сначала дорогие</ComboBoxItem>
                        <ComboBoxItem>по новинкам</ComboBoxItem>
                        <ComboBoxItem>по скидке</ComboBoxItem>
                        <ComboBoxItem>по количеству отзывов</ComboBoxItem>
                        <ComboBoxItem>сначала с лучшей оценкой</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="btnApply" Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" 
                        Content="Применить" Width="100" Height="30"
                        VerticalAlignment="Center" Margin="20,0,0,0"
                        Click="BtnApply_Click"/>

                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="10,5,0,5">
                    <TextBlock x:Name="tbSort" Text="Сортировка: сначала недорогие" Margin="0,0,15,0"/>
                    <TextBlock x:Name="tbCategory" Text="Категория: (не выбрана)"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="Black" BorderThickness="1" Padding="5" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <ToggleButton x:Name="btnList" Content="Список" Width="70" 
                                      Click="BtnList_Click" IsChecked="True"/>
                        <ToggleButton x:Name="btnTile" Content="Плитка" Width="70" 
                                      Click="BtnTile_Click" Margin="5,0,0,0"/>
                        <Button x:Name="btnBuy" Content="Купить" Width="70" 
                                Click="BtnBuy_Click" Margin="20,0,0,0"/>
                    </StackPanel>

                    <ListView x:Name="lvProducts" Grid.Row="1" 
                              SelectionMode="Single"
                              MouseDoubleClick="LvProducts_MouseDoubleClick">
                    </ListView>
                </Grid>
            </Border>

            <Border BorderBrush="Black" BorderThickness="1" Padding="5" Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Корзина" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <ListBox x:Name="lbCart" Grid.Row="1" 
                             SelectionMode="Extended"
                             DisplayMemberPath="Name"/>

                    <Button x:Name="btnRemove" Grid.Row="2" Content="Удалить" 
                            Margin="0,10,0,0" Height="30"
                            Click="BtnRemove_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>